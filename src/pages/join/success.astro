---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Stripe from "stripe";

const stripe = new Stripe(import.meta.env.STRIPE_SECRET_KEY);

const sessionId = Astro.url.searchParams.get("session_id") || "";

// const legacyResponse = await fetch(
//   `${import.meta.env.COUGARCS_LEGACY_API}/api/payment/sessionRegister`,
//   {
//     method: "POST",
//     headers: {
//       "Content-Type": "application/json",
//     },
//     body: JSON.stringify({
//       sessionId: sessionId,
//     }),
//   }
// );

let checkoutSession;
if (sessionId) {
  checkoutSession = await stripe.checkout.sessions.retrieve(sessionId);
} else {
  Astro.redirect("/join");
}

const memberFirstName = checkoutSession?.customer_details?.name?.split(" ")[0];
---

<BaseLayout>
  <div class="join-success">
    <div class="join-header">
      <h2>Thank you for joining CougarCS!</h2>
      <p>
        Your membership has been successfully processed, {memberFirstName}.
      </p>
    </div>

    <p>
      Welcome to the club! You've taken the first step towards ensuring a successful
      academic and professional career.
    </p>

    <div class="claim-card">
      <div class="claim-copy">
        <h3>Claim your membership on Discord</h3>
        <p>
          Use the command below in our server with the same email and 7-digit PSID you just used
          at checkout to unlock your member role.
        </p>
      </div>
      <img
        src="/join/claim_membership.png"
        alt="Example Discord command showing /claim psid and email fields"
      />
    </div>

    <p>
      If you have any questions or concerns <a href="/contact">
        please feel free to reach out to us.
      </a>
    </p>
  </div>
</BaseLayout>

<style>
  .join-success {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    padding: 10rem 4rem;

    background-color: rgb(224, 250, 224);

    .join-header {
      font-weight: bold;
      color: #07883b;

      h2 {
        font-family: "Chakra Petch", sans-serif;
        font-size: 2rem;
      }
    }

    a {
      font-weight: bold;
      color: #07883b;
    }

    .claim-card {
      display: grid;
      gap: 1rem;
      grid-template-columns: 1fr;
      align-items: center;
      padding: 1.5rem;
      border-radius: 1rem;
      background: #ffffff;
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);

      h3 {
        margin: 0 0 0.25rem;
        font-family: "Chakra Petch", sans-serif;
        font-size: 1.3rem;
        color: #0b5d2a;
      }

      p {
        margin: 0;
        color: #1f1f1f;
      }

      img {
        width: 100%;
        max-width: 520px;
        justify-self: center;
        border-radius: 0.75rem;
        border: 1px solid #e0e0e0;
        background: #0f172a;
      }
    }

    @media screen and (min-width: 768px) {
      padding: 10rem 4rem;
      height: 100;

      .join-header {
        font-weight: bold;

        h2 {
          font-family: "Chakra Petch", sans-serif;
          font-size: 3rem;
        }
      }

      p {
        max-width: 24rem;
      }

      .claim-card {
        grid-template-columns: 1.2fr 1fr;
        gap: 2rem;
        max-width: 45rem;
      }
    }
  }
</style>
